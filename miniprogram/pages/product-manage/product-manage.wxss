.page { padding-bottom: 20rpx; }
.search-bar { padding: 20rpx; }
.search-input { background: #fff; border-radius: 12rpx; padding: 16rpx 24rpx; font-size: 28rpx; }
.btn-add { font-size: 24rpx; padding: 8rpx 20rpx; background: #07C160; color: #fff; border-radius: 8rpx; border: none; }
.product-item { padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.product-name { font-size: 30rpx; margin-bottom: 4rpx; }
.btn-edit { background: none; color: #07C160; border: 1rpx solid #07C160; font-size: 22rpx; display: inline-block; margin-right: 8rpx; }
.btn-del { background: none; color: #FA5151; border: 1rpx solid #FA5151; font-size: 22rpx; display: inline-block; }
/* 弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; }
.modal { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); background: #fff; border-radius: 16rpx; padding: 40rpx; width: 600rpx; z-index: 101; }
.modal-title { font-size: 36rpx; font-weight: 600; margin-bottom: 24rpx; display: block; }
.modal-input { border: 1rpx solid #e0e0e0; border-radius: 8rpx; padding: 16rpx; margin-bottom: 16rpx; font-size: 28rpx; }
.btn-cancel { flex: 1; background: #f5f5f5; border: none; border-radius: 8rpx; }
.btn-save { flex: 1; background: #07C160; color: #fff; border: none; border-radius: 8rpx; }
.empty-tip { text-align: center; color: #999; padding: 40rpx 0; }
