.page { padding-bottom: 20rpx; }
.status-badge { font-size: 24rpx; padding: 4rpx 16rpx; border-radius: 24rpx; }
.badge-online { background: #e8f8ef; color: #07C160; }
.badge-offline { background: #f5f5f5; color: #999; }
.info-grid { display: flex; flex-wrap: wrap; margin-top: 16rpx; }
.info-item { width: 50%; margin-bottom: 12rpx; }
.info-label { font-size: 22rpx; color: #999; display: block; }
.info-value { font-size: 28rpx; color: #333; margin-top: 4rpx; }
.status-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.status-item {
    width: calc(50% - 8rpx);
    background: #f8f8f8;
    border-radius: 12rpx;
    padding: 20rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
}
.status-icon { font-size: 40rpx; margin-bottom: 8rpx; }
.status-text { font-size: 24rpx; }
.today-big { font-size: 48rpx; font-weight: 700; color: #07C160; margin-bottom: 8rpx; }
.order-item { padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.order-id { font-size: 26rpx; color: #666; }
.empty-tip { text-align: center; color: #999; padding: 40rpx 0; }
