.page { padding-bottom: 20rpx; }
.overview-cards {
    padding: 20rpx;
    gap: 16rpx;
}
.stat-card {
    flex: 1;
    background: #fff;
    border-radius: 16rpx;
    padding: 24rpx 16rpx;
    text-align: center;
    box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.stat-value { font-size: 36rpx; font-weight: 700; color: #07C160; display: block; }
.stat-label { font-size: 22rpx; color: #999; margin-top: 8rpx; display: block; }
.device-item {
    padding: 20rpx 0;
    border-bottom: 1rpx solid #f0f0f0;
    cursor: pointer;
}
.device-item:last-child { border-bottom: none; }
.dot { width: 16rpx; height: 16rpx; border-radius: 50%; margin-right: 16rpx; flex-shrink: 0; }
.dot-online { background: #07C160; box-shadow: 0 0 8rpx rgba(7,193,96,0.5); }
.dot-offline { background: #ccc; }
.device-name { font-size: 30rpx; margin-bottom: 4rpx; }
.device-info { font-size: 22rpx; }
.arrow { font-size: 36rpx; color: #ccc; margin-left: 8rpx; }
.device-warning { margin-top: 8rpx; font-size: 22rpx; color: #FA5151; }
.hot-item { padding: 12rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.empty-tip { text-align: center; color: #999; padding: 40rpx 0; }
