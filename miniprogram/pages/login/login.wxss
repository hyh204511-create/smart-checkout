.login-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 120rpx 0 80rpx;
    background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
}
.logo-area {
    display: flex;
    flex-direction: column;
    align-items: center;
}
.logo { width: 160rpx; height: 160rpx; margin-bottom: 32rpx; }
.logo-text { font-size: 120rpx; margin-bottom: 32rpx; }
.title { font-size: 40rpx; color: #fff; font-weight: 700; }
.subtitle { font-size: 26rpx; color: rgba(255,255,255,0.8); margin-top: 12rpx; }
.btn-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    padding: 0 60rpx;
}
.wx-login-btn {
    width: 100%;
    height: 96rpx;
    background: #fff;
    color: #07C160;
    font-size: 32rpx;
    font-weight: 600;
    border-radius: 48rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
}
.wx-icon { width: 40rpx; height: 40rpx; margin-right: 16rpx; }
.hint { font-size: 24rpx; color: rgba(255,255,255,0.7); margin-top: 24rpx; }
